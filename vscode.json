  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "foreground": "#888888",
          "fontStyle": "italic"
        }
      },
      {
        "scope": "string",
        "settings": {
          "foreground": "#ff8800"
        }
      },
      {
        "scope": "number",
        "settings": {
          "foreground": "#00ffff"
        }
      },
      {
        "scope": "keyword",
        "settings": {
          "foreground": "#00ff41"
        }
      },
      {
        "scope": "variable",
        "settings": {
          "foreground": "#00ff41"
        }
      },
      {
        "scope": "entity.name.function",
        "settings": {
          "foreground": "#66ff66"
        }
      }
    ]
  }
